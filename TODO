# Create necessary directories
mkdir -p /var/www/bibel-project/{logs,media,staticfiles}
mkdir -p /var/www/certbot/.well-known/acme-challenge
mkdir -p /var/www/bibel-project/nginx/sites-available

# Set permissions
chmod -R 755 /var/www/bibel-project

certbot certonly --standalone \
  -d www.preachly.app \
  -d api.preachly.app \
  --email info@preachly.app \
  --agree-tos \
  --no-eff-email \
  --non-interactive


dig preachly.app A +short
dig www.preachly.app A +short
dig api.preachly.app A +short